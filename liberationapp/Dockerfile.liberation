FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-liberation.txt ./
RUN pip install --no-cache-dir -r requirements-liberation.txt

COPY liberation.py ./
COPY liberation_servers.example.json ./

RUN mkdir -p /app/data

EXPOSE 8080

CMD ["python", "liberation.py"]